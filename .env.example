# YouTube Data API v3 keys
# Add up to 10 keys — they rotate automatically when one hits the daily quota limit
# On Railway: add these as environment variables in the service settings
YOUTUBE_API_KEY_1=your_key_1_here
YOUTUBE_API_KEY_2=your_key_2_here
YOUTUBE_API_KEY_3=your_key_3_here
YOUTUBE_API_KEY_4=your_key_4_here
YOUTUBE_API_KEY_5=your_key_5_here

# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server port (Railway sets this automatically)
PORT=3000

# Instantly AI (email outreach) — each push auto-creates a new campaign
INSTANTLY_API_KEY=your_instantly_api_key
